      "Piecewise surrogate frame PSNR: min/mean/max = 120.0 120.0 120.0\n"
     ]
    }
   ],
   "source": [
    "\n",
    "# -----------------------------\n",
    "# Piecewise bicubic surrogate video\n",
    "# -----------------------------\n",
    "G_poly = np.zeros_like(G, dtype=np.float32)\n",
    "coeffs_list = []\n",
    "\n",
    "for t in range(T):\n",
    "    coeffs, sigma_info = fit_bicubic_to_image(G[t], k=k)\n",
    "    img_poly, patch_map = reconstruct_image_from_coefficients(coeffs)\n",
    "    G_poly[t] = np.clip(img_poly.astype(np.float32), 0.0, 1.0)\n",
    "    coeffs_list.append({\n",
    "        \"coeffs\": coeffs,\n",
    "        \"sigmas\": sigma_info,\n",
    "        \"patch_map\": patch_map,\n",
    "    })\n",
    "\n",
    "frame_mse = np.mean((G - G_poly) ** 2, axis=(1, 2))\n",
    "frame_psnr = 10 * np.log10(1.0 / np.maximum(frame_mse, 1e-12))\n",
    "print(\"Piecewise surrogate frame PSNR: min/mean/max =\",\n",
    "      float(frame_psnr.min()), float(frame_psnr.mean()), float(frame_psnr.max()))\n"
   ]
  },
