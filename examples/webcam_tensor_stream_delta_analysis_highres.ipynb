   ],
   "source": [
    "\n",
    "# -----------------------------\n",
    "# Deltas of the surrogate video\n",
    "# -----------------------------\n",
    "Delta = np.zeros_like(G_poly, dtype=np.float32)\n",
    "Delta[1:] = G_poly[1:] - G_poly[:-1]\n",
    "\n",
    "G_cum = np.zeros_like(G_poly, dtype=np.float32)\n",
    "G_cum[0] = G_poly[0]\n",
    "G_cum[1:] = G_poly[0] + np.cumsum(Delta[1:], axis=0)\n",
    "\n",
    "cumsum_err = G_cum - G_poly\n",
    "cumsum_mse = np.mean(cumsum_err ** 2, axis=(1, 2))\n",
    "print(\"Cumsum identity MSE min/mean/max =\",\n",
    "      float(cumsum_mse.min()), float(cumsum_mse.mean()), float(cumsum_mse.max()))\n"
   ]
  },
