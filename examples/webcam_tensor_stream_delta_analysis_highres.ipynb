   "source": [
    "\n",
    "# -----------------------------\n",
    "# Bond-dimension sweep for delta transport\n",
    "# -----------------------------\n",
    "results = []\n",
    "\n",
    "delta_range = float(np.ptp(Delta[1:])) if T > 1 else 1.0\n",
    "delta_range = max(delta_range, 1e-8)\n",
    "\n",
    "for chi in BOND_DIMENSIONS:\n",
    "    recon_deltas = np.zeros_like(Delta)\n",
    "    payload_bytes = []\n",
    "\n",
    "    for t in range(1, T):\n",
    "        d_hat, n_bytes = compress_delta_as_mps(Delta[t], bond_dim=chi, dtype_bytes=DELTA_DTYPE_BYTES)\n",
    "        recon_deltas[t] = d_hat\n",
    "        payload_bytes.append(n_bytes)\n",
    "\n",
    "    recon_video = np.zeros_like(G_poly)\n",
    "    recon_video[0] = G_poly[0]\n",
    "    for t in range(1, T):\n",
    "        recon_video[t] = recon_video[t - 1] + recon_deltas[t]\n",
    "\n",
    "    payload_bytes = np.asarray(payload_bytes, dtype=float)\n",
    "    results.append({\n",
    "        \"bond_dim\": chi,\n",
    "        \"delta_psnr\": psnr(Delta[1:], recon_deltas[1:], data_range=delta_range),\n",
    "        \"video_psnr_vs_piecewise\": psnr(G_poly, recon_video, data_range=1.0),\n",
    "        \"mean_payload_bytes\": float(np.mean(payload_bytes)),\n",
    "        \"median_payload_bytes\": float(np.median(payload_bytes)),\n",
    "        \"max_payload_bytes\": float(np.max(payload_bytes)),\n",
    "        \"total_payload_bytes\": float(np.sum(payload_bytes)),\n",
    "        \"compression_ratio\": float(np.mean(payload_bytes) / (H * W * DELTA_DTYPE_BYTES)),\n",
    "    })\n",
    "\n",
    "results\n"
   ]
  },
