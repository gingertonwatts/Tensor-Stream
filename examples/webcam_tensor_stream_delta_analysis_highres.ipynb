   "source": [
    "\n",
    "# Webcam delta compression study with `tensor_stream`\n",
    "\n",
    "This notebook mirrors the webcam capture workflow from your earlier notebook, but updates the imports to use\n",
    "`tensor_stream` and pushes the main analysis to the **frame-to-frame deltas** at the end.\n",
    "\n",
    "The workflow is:\n",
    "\n",
    "1. Capture grayscale webcam frames.\n",
    "2. Build the piecewise bicubic surrogate of each frame with `tensor_stream`.\n",
    "3. Form frame-to-frame deltas from the surrogate video.\n",
    "4. Analyze why the deltas are compressible.\n",
    "5. Sweep TT/MPS bond dimensions and report **KB per update** and the **accuracy–bandwidth frontier**.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0d7af1e8",
   "metadata": {}
   ],
   "source": [
    "\n",
    "from pathlib import Path\n",
    "import sys\n",
    "import shutil\n",
    "\n",
    "# Make local imports work as `tensor_stream`, even if the package is not yet installed.\n",
    "root = Path.cwd()\n",
    "src_dir = root / \"src\"\n",
    "pkg_dir = root / \"tensor_stream\"\n",
    "\n",
    "if (src_dir / \"tensor_stream\").exists():\n",
    "    if str(src_dir) not in sys.path:\n",
    "        sys.path.insert(0, str(src_dir))\n",
    "elif not pkg_dir.exists():\n",
    "    pkg_dir.mkdir(exist_ok=True)\n",
    "    file_map = {\n",
    "        \"__init__.py\": \"__init__.py\",\n",
    "        \"indexing.py\": \"indexing.py\",\n",
    "        \"piecewise.py\": \"piecewise.py\",\n",
    "        \"polynomial_tt.py\": \"polynomial_tt.py\",\n",
    "    }\n",
    "    for src_name, dst_name in file_map.items():\n",
    "        src = root / src_name\n",
    "        if src.exists():\n",
    "            shutil.copy2(src, pkg_dir / dst_name)\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import cv2\n",
    "import quimb.tensor as qtn\n",
    "\n",
    "from tensor_stream import fit_bicubic_to_image, reconstruct_image_from_coefficients\n",
    "\n",
    "print(\"Using tensor_stream from:\", Path(sys.modules['tensor_stream'].__file__).resolve())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "8066b3b9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# -----------------------------\n",
    "# Config\n",
    "# -----------------------------\n",
    "DEVICE_INDEX = 0\n",
    "N_FRAMES = 60\n",
    "\n",
    "# Ask the webcam for a higher native capture resolution if supported.\n",
    "CAMERA_WIDTH = 1280\n",
    "CAMERA_HEIGHT = 720\n",
    "\n",
    "# Analysis resolution after preprocessing.\n",
    "# Keep TARGET_SIZE = 4 * 2^k so the piecewise bicubic patching stays valid.\n",
    "TARGET_SIZE = 256\n",
    "SHOW_LIVE = True\n",
    "CAPTURE_EVERY = 1         # keep every CAPTURE_EVERY-th webcam frame\n",
    "\n",
    "BOND_DIMENSIONS = [2, 4, 8, 16, 32, 64]\n",
    "DELTA_DTYPE_BYTES = 4     # float32 payload baseline\n",
    "DELTA_THRESHOLD_FRACS = [0.005, 0.01, 0.02, 0.05]\n",
    "MAX_SAMPLE_DELTAS = 6\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d3f0662c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Requested webcam resolution: 1280 x 720\n",
      "Actual webcam resolution:    1280 x 720\n",
      "Capturing webcam frames... press 'q' to stop early.\n",
      "Captured 60 frames.\n"
     ]
    }
   ],
   "source": [
    "# -----------------------------\n",
    "# Webcam capture\n",
    "# -----------------------------\n",
    "cap = cv2.VideoCapture(DEVICE_INDEX)\n",
    "if not cap.isOpened():\n",
    "    raise RuntimeError(\"Could not open webcam. Try DEVICE_INDEX=1 or check camera permissions.\")\n",
    "\n",
    "# Request a higher capture resolution. The camera may ignore these if unsupported.\n",
    "cap.set(cv2.CAP_PROP_FRAME_WIDTH, CAMERA_WIDTH)\n",
    "cap.set(cv2.CAP_PROP_FRAME_HEIGHT, CAMERA_HEIGHT)\n",
    "\n",
    "actual_width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n",
    "actual_height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n",
    "print(f\"Requested webcam resolution: {CAMERA_WIDTH} x {CAMERA_HEIGHT}\")\n",
    "print(f\"Actual webcam resolution:    {actual_width} x {actual_height}\")\n",
    "\n",
    "frames_bgr = []\n",
    "print(\"Capturing webcam frames... press 'q' to stop early.\")\n",
    "read_count = 0\n",
    "while len(frames_bgr) < N_FRAMES:\n",
    "    ok, frame = cap.read()\n",
    "    if not ok:\n",
    "        print(f\"Frame read failed at camera read {read_count}.\")\n",
    "        break\n",
    "    if read_count % CAPTURE_EVERY == 0:\n",
    "        frames_bgr.append(frame)\n",
    "        if SHOW_LIVE:\n",
    "            disp = frame.copy()\n",
    "            cv2.putText(disp, f\"captured {len(frames_bgr)}/{N_FRAMES}\", (15, 30),\n",
    "                        cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2, cv2.LINE_AA)\n",
    "            cv2.imshow(\"Live webcam (press q to stop)\", disp)\n",
    "            if cv2.waitKey(1) & 0xFF == ord('q'):\n",
    "                break\n",
    "    read_count += 1\n",
    "\n",
    "cap.release()\n",
    "cv2.destroyAllWindows()\n",
    "print(f\"Captured {len(frames_bgr)} frames.\")\n",
    "if len(frames_bgr) < 2:\n",
    "    raise RuntimeError(\"Need at least 2 frames for delta analysis.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "dbf91605",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "G shape: (60, 256, 256)\n",
      "Intensity range: (0.0235294122248888, 1.0)\n",
      "Derived patch-grid exponent k = 6 (64 x 64 bicubic blocks)\n"
     ]
    }
   ],
   "source": [
    "def preprocess_frames(frames_bgr, target_size):\n",
    "    out = []\n",
    "    for fr in frames_bgr:\n",
    "        gray = cv2.cvtColor(fr, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "        # Center-crop to a square before resizing so we do not distort the image.\n",
    "        h, w = gray.shape\n",
    "        side = min(h, w)\n",
    "        y0 = (h - side) // 2\n",
    "        x0 = (w - side) // 2\n",
    "        gray_sq = gray[y0:y0 + side, x0:x0 + side]\n",
    "\n",
    "        gray_rs = cv2.resize(gray_sq, (target_size, target_size), interpolation=cv2.INTER_AREA)\n",
    "        out.append(gray_rs.astype(np.float32) / 255.0)\n",
    "    return np.stack(out, axis=0)\n",
    "\n",
    "G = preprocess_frames(frames_bgr, TARGET_SIZE)\n",
    "T, H, W = G.shape\n",
    "print(\"G shape:\", G.shape)\n",
    "print(\"Intensity range:\", (float(G.min()), float(G.max())))\n",
    "\n",
    "if TARGET_SIZE % 4 != 0:\n",
    "    raise ValueError(\"TARGET_SIZE must be divisible by 4.\")\n",
    "patch_blocks = TARGET_SIZE // 4\n",
    "if (patch_blocks & (patch_blocks - 1)) != 0:\n",
    "    raise ValueError(\"TARGET_SIZE / 4 must be a power of two, so TARGET_SIZE = 4 * 2^k.\")\n",
    "k = int(np.log2(patch_blocks))\n",
    "print(f\"Derived patch-grid exponent k = {k} ({2**k} x {2**k} bicubic blocks)\")\n"
   ]
  },
