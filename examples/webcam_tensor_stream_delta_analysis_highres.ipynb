    "\n",
    "# -----------------------------\n",
    "# Why are the deltas compressible?\n",
    "# -----------------------------\n",
    "abs_delta = np.abs(Delta[1:])\n",
    "raw_payload_kb = (H * W * DELTA_DTYPE_BYTES) / 1024.0\n",
    "\n",
    "l1_per_frame = np.mean(abs_delta, axis=(1, 2))\n",
    "l2_per_frame = np.sqrt(np.mean(Delta[1:] ** 2, axis=(1, 2)))\n",
    "linf_per_frame = np.max(abs_delta, axis=(1, 2))\n",
    "\n",
    "occupancy = {}\n",
    "for frac in DELTA_THRESHOLD_FRACS:\n",
    "    occupancy[frac] = np.mean(abs_delta > frac, axis=(1, 2))\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(13, 8))\n",
    "\n",
    "axes[0, 0].plot(np.arange(1, T), l1_per_frame, 'o-', label='mean |Δ|')\n",
    "axes[0, 0].plot(np.arange(1, T), l2_per_frame, 's--', label='RMS(Δ)')\n",
    "axes[0, 0].set_title('Delta magnitude over time')\n",
    "axes[0, 0].set_xlabel('frame t')\n",
    "axes[0, 0].set_ylabel('magnitude')\n",
    "axes[0, 0].grid(True, alpha=0.25)\n",
    "axes[0, 0].legend()\n",
    "\n",
    "for frac in DELTA_THRESHOLD_FRACS:\n",
    "    axes[0, 1].plot(np.arange(1, T), occupancy[frac], marker='o', label=f'|Δ| > {frac:.3f}')\n",
    "axes[0, 1].set_title('Fraction of active pixels in each delta')\n",
    "axes[0, 1].set_xlabel('frame t')\n",
    "axes[0, 1].set_ylabel('active fraction')\n",
    "axes[0, 1].grid(True, alpha=0.25)\n",
    "axes[0, 1].legend()\n",
    "\n",
    "axes[1, 0].hist(Delta[1:].ravel(), bins=121, density=True)\n",
    "axes[1, 0].set_title('Histogram of surrogate-video deltas')\n",
    "axes[1, 0].set_xlabel('delta value')\n",
    "axes[1, 0].set_ylabel('density')\n",
    "axes[1, 0].grid(True, alpha=0.25)\n",
    "\n",
    "axes[1, 1].plot(np.arange(1, T), linf_per_frame, 'o-')\n",
    "axes[1, 1].set_title('Peak delta magnitude per frame')\n",
    "axes[1, 1].set_xlabel('frame t')\n",
    "axes[1, 1].set_ylabel('max |Δ|')\n",
    "axes[1, 1].grid(True, alpha=0.25)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Raw float32 delta payload per update: {raw_payload_kb:.3f} KB\")\n",
    "print(\"Mean active-pixel fractions:\")\n",
    "for frac in DELTA_THRESHOLD_FRACS:\n",
    "    print(f\"  |Δ| > {frac:.3f}: {float(np.mean(occupancy[frac])):.4f}\")\n"
   ]
